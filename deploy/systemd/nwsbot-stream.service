[Unit]
Description=NWSBot Twitch/YouTube Chat Bot
After=network.target nwsweb-api.service
Wants=nwsweb-api.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/nwsbot-stream
ExecStart=/usr/bin/node src/bot.js
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nwsbot-stream
EnvironmentFile=/opt/nwsbot-stream/.env

[Install]
WantedBy=multi-user.target
