{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NordwindHub",
  "version": "0.1.0",
  "identifier": "io.nordwind.companion",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/app",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NordwindHub",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nordwind"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Nordwind Virtual",
    "copyright": "© Nordwind Virtual (VNWS)",
    "category": "Utility",
    "shortDescription": "NordwindHub — десктоп-компаньон пилота",
    "longDescription": "NordwindHub — приложение пилота Nordwind Virtual: рейсы, карта, галерея, чат, радио, ассистент.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Russian", "English"]
      }
    }
  }
}
